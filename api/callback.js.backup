export default function handler(req, res) {
    if (req.method === 'POST') {
        const data = req.body;
        
        // Convert the entire body object into a URL query string
        const queryParams = new URLSearchParams(data).toString();

        // --- 1. HANDLE INQUIRY (INQ) RESPONSES ---
        // Used when the "Check Status" button is clicked in the iframe
        if (data.MPI_TRANS_TYPE === "INQ") {
            res.setHeader('Content-Type', 'text/html');
            return res.status(200).send(`
                <script>
                    if (window.parent) {
                        window.parent.postMessage(${JSON.stringify(data)}, "*");
                    }
                </script>
            `);
        }

        // --- 2. ROUTING LOGIC ---
        let destination = "";
        if (data.MPI_QR_CODE) {
            destination = "/pag/iframe/redirect-03.html";
        } else if (data.MPI_REDIRECT_URL && data.MPI_REDIRECT_HTTP_DATA) {
            destination = "/pag/iframe/redirect-01.html";
        } else if (data.MPI_REDIRECT_URL) {
            destination = "/pag/iframe/redirect-02.html";
        }

        // --- 3. RENDER REDIRECT UI ---
        if (destination !== "") {
            res.setHeader('Content-Type', 'text/html');
            return res.status(200).send(`
                <html>
                <head>
                    <style>
                        body { font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; background: #f4f4f9; }
                        .wrapper { background: white; border: 1px solid #ddd; padding: 30px; border-radius: 8px; text-align: center; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
                        .btn { background: black; color: white; padding: 12px 25px; text-decoration: none; border-radius: 4px; display: inline-block; margin-top: 20px; font-weight: bold; }
                    </style>
                </head>
                <body>
                    <div class="wrapper">
                        <h2>Payment Ready</h2>
                        <p>Click below to view your DuitNow QR Code.</p>
                        <a href="${destination}?${queryParams}" class="btn">Continue to Payment</a>
                    </div>
                </body>
                </html>
            `);
        } else {
            // Fallback for final status
            return res.redirect(302, `/payment-status.html?${queryParams}`);
        }
    } else {
        res.status(405).json({ error: "Method Not Allowed" });
    }
}
